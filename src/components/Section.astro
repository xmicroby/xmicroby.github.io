---
import Container from './Container.astro';

interface Props {
  id: string;
  label: string;
  title: string;
}

const { id, label, title } = Astro.props;
---

<section id={id} class="py-12 md:py-16 min-h-[50vh]">
  <Container>
    <span class="font-mono text-sm text-[var(--color-accent)] tracking-[0.04em] leading-[1.5]">
      {label}
    </span>
    <h2 class="text-[var(--color-text)] mt-2 mb-8">
      {title}
    </h2>
    <slot />
  </Container>
</section>

---
import Container from './Container.astro';
import MobileNav from './MobileNav.astro';

const navLinks = [
  { label: 'Home', href: '#' },
  { label: 'About', href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 h-14 md:h-16 bg-[var(--color-surface)]/85 backdrop-blur-[12px] border-b border-[var(--color-border)]">
  <Container>
    <nav class="flex items-center justify-between h-14 md:h-16">
      <a href="#" class="font-mono text-sm text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors duration-200">
        Youngbin Kim
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="nav-link font-mono text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 relative after:absolute after:bottom-[-4px] after:left-1/2 after:w-0 after:h-[2px] after:bg-[var(--color-accent)] after:transition-all after:duration-200 after:ease-in-out hover:after:left-0 hover:after:w-full"
              data-section={link.href.replace('#', '') || 'home'}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile hamburger button -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="block w-5 h-0.5 bg-[var(--color-text)] transition-transform duration-200"></span>
        <span class="block w-5 h-0.5 bg-[var(--color-text)] transition-opacity duration-200"></span>
        <span class="block w-5 h-0.5 bg-[var(--color-text)] transition-transform duration-200"></span>
      </button>
    </nav>
  </Container>

  <MobileNav navLinks={navLinks} />
</header>
